# Beispiel-Konfigurationsdatei für das Frontend
# Kopiere diese Datei und benenne sie in .env.development oder .env.production um

# API Base URL - die Basis-URL für alle API-Aufrufe und Ressourcen
# In Development: http://localhost:8000
# In Production: https://api.example.com
VITE_API_BASE_URL=

# Debug Modus - aktiviert zusätzliche Debug-Informationen
# Mögliche Werte: true, false
VITE_DEBUG=

# Weitere Konfigurationsoptionen können hier hinzugefügt werden
# VITE_ANOTHER_OPTION=